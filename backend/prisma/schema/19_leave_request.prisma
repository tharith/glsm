// ─── MODULE 5A: LEAVE_REQUEST ───────────────────────────────────
// ឯកសារឌីជីថលដើម (Primary Document) នៃ ពាក្យសុំច្បាប់
// refNumber: LR-YYYY-XXXX (auto-generated)
// status tracks current lifecycle position
// ហ្វ្លូ: DRAFT → SUBMITTED → [approval steps] → COMPLETED
//       ឬ → REJECTED | RETURNED | CANCELLED

model LeaveRequest {
  id          String      @id @default(cuid())
  refNumber   String      @unique              // LR-2025-0001
  userId      String
  leaveTypeId String
  startDate   DateTime
  endDate     DateTime
  totalDays   Float                            // working days only
  isHalfDay   Boolean     @default(false) @map("is_half_day") // ច្បាប់កន្លះថ្ងៃ
  reason      String
  status      LeaveStatus @default(DRAFT)
  submittedAt DateTime?
  completedAt DateTime?
  requesterSignatureUrl String?   // ហត្ថលេខាអ្នកស្នើសុំ (optional, uploaded at submit time)
  isDeleted   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user             User              @relation(fields: [userId],      references: [id])
  leaveType        LeaveType         @relation(fields: [leaveTypeId], references: [id])
  approvals        LeaveApproval[]
  attachments      LeaveAttachment[]
  histories        LeaveHistory[]
  workflowInstance WorkflowInstance?

  notifications          Notification[]

  // Critical indexes — most queried table
  @@index([userId])                          // my requests
  @@index([status])                          // filter by status
  @@index([userId, status])                  // my pending/completed
  @@index([leaveTypeId])                     // filter by type
  @@index([submittedAt])                     // sort by submission date
  @@index([startDate, endDate])              // date range queries
  @@index([isDeleted, status])               // active requests
  @@map("leave_requests")
}

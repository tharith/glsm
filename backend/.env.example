# Database
DATABASE_URL="postgresql://postgres:1234567890@localhost:5432/glms_db?schema=public"

# JWT
JWT_ACCESS_SECRET=glms_access_super_secret_change_me_in_production
JWT_REFRESH_SECRET=glms_refresh_super_secret_change_me_in_production
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# App
PORT=3000
NODE_ENV=development

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
